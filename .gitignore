# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
src/*.egg-info/
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# Env / secrets
.env
.env.*
!.env.example

# IDEs / editors
.vscode/
.idea/
*.swp

# OS junk
.DS_Store
Thumbs.db

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Logs
*.log

# ─────────────────────────────────────────────────────────────────────────────
# USER-GENERATED / RUNTIME DATA — never tracked.
# Created when users run conversions/generations. Anchored at the runtime root
# (repo root in dev, PHANSORA_DATA_DIR in prod). The directory structure is kept
# via .gitkeep files; the contents are ignored.
# ─────────────────────────────────────────────────────────────────────────────

# SpokenVerse — generated audio/text, history, upload staging
output_audio/
output_txt/
history/
input_pdf/
input_txt/
.tmp_uploads/

# Book Alchemy — per-user source uploads + narrated session audio
/book_alchemy/

# Dossier Nova — temp uploads + generated TOC output
tmp/
toc/

# Dossier Nova — cumulative local vector store (appended to on every generation)
data/dossier_nova/*
!data/dossier_nova/.gitkeep

# Chrono-Origin — cached trace results (written on every trace)
data/chrono_origin/cache/*
!data/chrono_origin/cache/.gitkeep

# Any stray SQLite stores
*.db
*.sqlite
*.sqlite3

# systemd unit files are environment-specific
*.service
