# ═══════════════════════════════════════════════════════════════════════════
# Phanoris API — environment configuration
# Copy to .env and fill in. Each product reads only the keys it needs; a product
# whose required keys are absent simply won't mount (the others still serve).
# ═══════════════════════════════════════════════════════════════════════════

# ── Platform ──
PHANORIS_APP_NAME=Phanoris API
HOST=0.0.0.0
PORT=8000
CORS_ALLOW_ORIGINS=https://phanoris.com,https://www.phanoris.com,http://localhost:3000
# Optional: comma-separated subset to expose (default = every product that imports)
# PHANORIS_ENABLED_PRODUCTS=spokenverse,chrono_origin,dossier_nova

# ═══ SpokenVerse ═══════════════════════════════════════════════════════════
# TTS engine (StyleTTS2 voice cloning)
TTS_ENGINE=styletts2
STYLETTS2_REF_AUDIO=
STYLETTS2_DIFFUSION_STEPS=10
STYLETTS2_ALPHA=0.3
STYLETTS2_BETA=0.7
STYLETTS2_EMBEDDING_SCALE=1.0
STYLETTS2_CHECKPOINT=
STYLETTS2_CONFIG=

# DeepSeek chat (PDF OCR cleanup + Book Alchemy) — note the *_CHAT_* names
DEEPSEEK_CHAT_API_KEY=your_deepseek_api_key
DEEPSEEK_CHAT_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Local transcription (faster-whisper)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=true
# WHISPER_CPU_THREADS=
# WHISPER_NUM_WORKERS=

# Contact-form email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DEFAULT_FROM=
EMAIL_TO=

# Book Alchemy — Postgres + durable worker
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=phanoris
DB_PASSWORD=phanoris
DB_NAME=phanoris
DB_POOL_MAX=5
BOOK_ALCHEMY_DB_POOL=5
BOOK_ALCHEMY_USE_GPU=false
BOOK_ALCHEMY_TTS_CONCURRENCY=4
BOOK_ALCHEMY_LEASE_SECONDS=600
BOOK_ALCHEMY_IDLE_SLEEP=5

# ═══ Chrono-Origin ═════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_SEARCH_MODEL=claude-sonnet-4-6
ANTHROPIC_REASONING_MODEL=claude-opus-4-8
ANTHROPIC_SEARCH_MAX_TOKENS=4096
ANTHROPIC_REASON_MAX_TOKENS=16000
CHRONO_MAX_DEPTH=4
CHRONO_MAX_SOURCES_PER_STAGE=8
CHRONO_MAX_QUERIES_PER_STAGE=5
CHRONO_SEARCH_MAX_USES=4
CHRONO_REQUEST_TIMEOUT_S=120
CHRONO_CACHE_DIR=./data/chrono_origin/cache

# ═══ Dossier Nova ══════════════════════════════════════════════════════════
# DeepSeek via OpenAI-compatible client — note the plain DEEPSEEK_* names
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_SECONDS=90
DEEPSEEK_MAX_RETRIES=1
SIMILARITY_THRESHOLD=0.75
EMBEDDING_DIMENSIONS=384
MAX_CHUNK_CHARS=20000
CONSERVATIVE_MODE=false
CATCHALL_HEADING=Miscellaneous
TOC_TARGET_HEADING_COUNT=60
CONTENT_SIMILARITY_THRESHOLD=0.95
OVERLAP_PARAGRAPHS=2
COVERAGE_THRESHOLD=0.85
CLEAN_EXTRACTED_TEXT=true
CLEANUP_CHUNK_SIZE=12000
SEMANTIC_SIMILARITY_DROP=0.2
MAX_SOURCE_SHARE=0.40
CLAIM_DEDUP_THRESHOLD=0.90
MAX_DUPLICATION_RATIO=0.15
ENABLE_SOURCE_PROFILING=true
PROFILE_SAMPLE_CHARS=4000
