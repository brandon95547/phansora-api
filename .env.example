# Phansora API — environment template. Copy to .env and fill in.
#
# FORMAT RULE: keep comments on their OWN lines. python-dotenv and systemd's
# EnvironmentFile treat everything after `=` as the value, so `PORT=8000  # x`
# becomes the literal "8000  # x" and breaks int parsing. No inline comments.
#
# See README "Environment (.env)" for which vars differ between dev and prod.

# ═══ App / server ═══════════════════════════════════════════════
PHANSORA_APP_NAME=Phansora API
HOST=0.0.0.0
PORT=8000
# [prod] where voices/audio/db live; leave unset in dev to use the cwd
# PHANSORA_DATA_DIR=/var/lib/phansora
# [required] comma-separated site origins. dev: http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000

# ═══ TTS engine — GPT-SoVITS ════════════════════════════════════
TTS_ENGINE=gptsovits
# path to the checkout. dev(mac): ~/GPT-SoVITS   prod: /var/www/GPT-SoVITS
GPTSOVITS_REPO=
# 1 on a CUDA GPU (prod), 0 on Mac/CPU (dev)
GPTSOVITS_USE_GPU=0
# keep 0 — fp16 can produce silent output on some GPUs
GPTSOVITS_IS_HALF=0
# reference clip (+ its transcript) for the "Default" voice; optional
GPTSOVITS_DEFAULT_REF=
GPTSOVITS_DEFAULT_REF_TEXT=
# optional overrides:
# GPTSOVITS_DEVICE=cuda        # or mps / cpu — overrides auto-detect
# GPTSOVITS_LANGUAGE=en
# GPTSOVITS_T2S= / _VITS= / _BERT= / _HUBERT=   # model path overrides

# ═══ Whisper (audio→text + create-voice transcript) ═════════════
WHISPER_MODEL=base
# dev: cpu   prod: cuda if supported, else cpu
WHISPER_DEVICE=cpu
# cuda→float16, cpu→int8
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=true

# ═══ Database (Postgres) — shared with the Node site ════════════
# Same Postgres server as the website; DB_PORT must match it.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_POOL_MAX=5

# ═══ Book Alchemy ═══════════════════════════════════════════════
# [prod] 1 on GPU
BOOK_ALCHEMY_USE_GPU=0
BOOK_ALCHEMY_TTS_CONCURRENCY=4
BOOK_ALCHEMY_DB_POOL=4
BOOK_ALCHEMY_LEASE_SECONDS=300
BOOK_ALCHEMY_IDLE_SLEEP=5

# ═══ Email (SMTP) — contact form ════════════════════════════════
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DEFAULT_FROM=
EMAIL_TO=

# ═══ Chrono-Origin (Anthropic) ══════════════════════════════════
ANTHROPIC_API_KEY=
ANTHROPIC_SEARCH_MODEL=claude-sonnet-4-6
ANTHROPIC_REASONING_MODEL=claude-opus-4-8
ANTHROPIC_SEARCH_MAX_TOKENS=4096
ANTHROPIC_REASON_MAX_TOKENS=8192

# ═══ Dossier Nova (DeepSeek) ════════════════════════════════════
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=90
DEEPSEEK_MAX_RETRIES=1
