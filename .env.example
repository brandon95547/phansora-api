###############################################################################
# Phansora API — environment configuration (production template)
#
# Copy to `.env` and fill in the REQUIRED values. Everything shown with a value
# is the code's built-in default — you only need to set it to override.
# All products load automatically (a product whose optional heavy deps are
# missing is skipped with a warning). Secrets have NO default — leave blank here
# and set the real value in your deployment's secret manager.
###############################################################################

# ─────────────────────────────────────────────────────────────────────────────
# Platform / HTTP (always used)
# ─────────────────────────────────────────────────────────────────────────────
PHANSORA_APP_NAME=Phansora API
PHANSORA_VERSION=0.1.0
HOST=0.0.0.0
PORT=8000
# Comma-separated allowed CORS origins. Use real domains in prod, not "*".
CORS_ALLOW_ORIGINS=https://yourdomain.com
# Runtime data/cache root (defaults to the current working directory).
PHANSORA_DATA_DIR=/var/lib/phansora

# Admin storage endpoints (/admin/storage/*). Unset = locked (403 on all admin
# calls). Set to a long random string; the Node frontend sends it as X-Admin-Key.
PHANSORA_ADMIN_KEY=        # REQUIRED to use the admin Storage panel — secret
# Absolute paths used only for the storage size report (optional overrides).
PHANSORA_FRONTEND_DIR=/var/www/phansora
# PHANSORA_API_DIR=/var/www/phansora-api   # defaults to the installed repo root

# ─────────────────────────────────────────────────────────────────────────────
# Database — REQUIRED for book_alchemy (Postgres)
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=                 # REQUIRED (no default)
DB_USER=                 # REQUIRED (no default)
DB_PASSWORD=             # REQUIRED — secret
DB_POOL_MAX=5

# ─────────────────────────────────────────────────────────────────────────────
# Chrono-Origin — LLM provider
#   CHRONO_LLM_PROVIDER=openai   -> GPT-5 Nano + native web_search tool (default)
#   CHRONO_LLM_PROVIDER=deepseek -> DeepSeek + external web search (below)
# ─────────────────────────────────────────────────────────────────────────────
CHRONO_LLM_PROVIDER=openai

# -- OpenAI (used when provider=openai; GPT-5 Nano searches the web itself) --
# NOTE: keep values on their own with no trailing "# comment" — the value is read
# verbatim. OPENAI_MODEL is used for both search + reasoning unless overridden.
OPENAI_API_KEY=              # REQUIRED for openai — secret (empty value, comment ok)
OPENAI_MODEL=gpt-5-nano
# OPENAI_SEARCH_MODEL=gpt-5-nano     # uncomment to override the search model only
# OPENAI_REASONING_MODEL=gpt-5-nano
# Reasoning effort: minimal | low | medium | high
OPENAI_REASON_EFFORT=medium
OPENAI_LIGHT_EFFORT=low
OPENAI_SEARCH_EFFORT=low
OPENAI_REASON_MAX_TOKENS=8000
OPENAI_SEARCH_MAX_TOKENS=4000
# OPENAI_WEB_SEARCH_TOOL=web_search  # set to web_search_preview on older API tiers
# OPENAI_BASE_URL=                   # optional; blank = api.openai.com

# -- DeepSeek (used when provider=deepseek fallback; also Dossier Nova / SpokenVerse OCR) --
DEEPSEEK_API_KEY=              # REQUIRED for deepseek/dossier — secret
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONING_MODEL=deepseek-chat
DEEPSEEK_REASON_MAX_TOKENS=8000
DEEPSEEK_SEARCH_MAX_TOKENS=1024

# ─────────────────────────────────────────────────────────────────────────────
# Chrono-Origin — web search backend (ONLY used when provider=deepseek; the
# openai provider searches natively and ignores everything in this block)
#   brave (recommended, reliable) | searxng (self-hosted) | duckduckgo (keyless)
# ─────────────────────────────────────────────────────────────────────────────
CHRONO_SEARCH_PROVIDER=brave
CHRONO_SEARCH_RESULTS=5
BRAVE_API_KEY=               # REQUIRED if provider=brave — secret
SEARXNG_URL=                 # REQUIRED if provider=searxng, e.g. https://searx.example.com

# -- Chrono-Origin pipeline tuning (optional; defaults shown) --
CHRONO_MAX_DEPTH=4
CHRONO_MAX_SOURCES_PER_STAGE=8
CHRONO_MAX_QUERIES_PER_STAGE=5
CHRONO_REQUEST_TIMEOUT_S=120
CHRONO_CACHE_DIR=./data/chrono_origin/cache

# ─────────────────────────────────────────────────────────────────────────────
# Dossier Nova (uses DEEPSEEK_API_KEY above)
# ─────────────────────────────────────────────────────────────────────────────
DEEPSEEK_TIMEOUT_SECONDS=90
DEEPSEEK_MAX_RETRIES=1
INPUT_TEXT_PATH=              # optional; defaults under PHANSORA_DATA_DIR/tmp/pizza.txt
TOC_FULL_PATH=                # optional; defaults under PHANSORA_DATA_DIR/toc/full.md
ENABLE_SOURCE_PROFILING=true
CLEAN_EXTRACTED_TEXT=true
CONSERVATIVE_MODE=false
CATCHALL_HEADING=Miscellaneous
# Embedding / chunking / dedup tuning (optional; defaults shown)
EMBEDDING_DIMENSIONS=384
SIMILARITY_THRESHOLD=0.75
CONTENT_SIMILARITY_THRESHOLD=0.95
SEMANTIC_SIMILARITY_DROP=0.2
MAX_CHUNK_CHARS=20000
CLEANUP_CHUNK_SIZE=12000
OVERLAP_PARAGRAPHS=2
COVERAGE_THRESHOLD=0.85
TOC_TARGET_HEADING_COUNT=60
PROFILE_SAMPLE_CHARS=4000
MAX_SOURCE_SHARE=0.40
CLAIM_DEDUP_THRESHOLD=0.90
MAX_DUPLICATION_RATIO=0.15

# ─────────────────────────────────────────────────────────────────────────────
# SpokenVerse — text→speech (CosyVoice2) and speech→text (Whisper)
# ─────────────────────────────────────────────────────────────────────────────
# TTS engine selector (leave blank to use the product default).
TTS_ENGINE=
COSYVOICE2_REPO=
COSYVOICE2_MODEL_DIR=
COSYVOICE2_REF_AUDIO=
COSYVOICE2_DEFAULT_REF=
COSYVOICE2_DEFAULT_REF_TEXT=
COSYVOICE2_LANGUAGE=
# Whisper (STT) — optional; defaults shown
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=true
WHISPER_CPU_THREADS=
WHISPER_NUM_WORKERS=

# -- Legacy DeepSeek OCR-cleaner names (only if not using the canonical DEEPSEEK_* above) --
# DEEPSEEK_CHAT_API_KEY=
# DEEPSEEK_CHAT_BASE_URL=https://api.deepseek.com
# DEEPSEEK_CHAT_MODEL=deepseek-chat

# ─────────────────────────────────────────────────────────────────────────────
# Book Alchemy — async worker tuning (optional; defaults shown)
# ─────────────────────────────────────────────────────────────────────────────
BOOK_ALCHEMY_DB_POOL=5
BOOK_ALCHEMY_IDLE_SLEEP=5
BOOK_ALCHEMY_LEASE_SECONDS=600
BOOK_ALCHEMY_TTS_HTTP_TIMEOUT_S=3600

# ─────────────────────────────────────────────────────────────────────────────
# Email / SMTP notifications (only if a product sends email)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=               # REQUIRED to send email
SMTP_PORT=587
SMTP_USER=               # REQUIRED to send email
SMTP_PASS=               # REQUIRED to send email — secret
DEFAULT_FROM=            # defaults to SMTP_USER if unset
EMAIL_TO=                # notification recipient
PHANSORA_API_BASE=http://127.0.0.1:8000
